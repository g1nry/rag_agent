# ─────────────────────────────────────────────────────────────────────────────
# rails_output_safety.co
#
# Output rails mirroring the input safety catalog. These fire on $bot_response
# and block the answer if the model actually PRODUCED forbidden content. To
# avoid blocking refusals and educational discussion, rules match operational /
# instructional signatures (ingredients, precursors, code, data leaks), not bare
# topic words — i.e. what compliance looks like, not what the topic is.
#
# Executed in-process by guardrails.py (reads all *.co). Case-insensitive.
# ─────────────────────────────────────────────────────────────────────────────


# ── Secrets / API keys / credentials leaked in the answer ────────────────────
define flow output_secret_credential_leak
  if "-----begin rsa private key" in $bot_response
    bot say "Ответ заблокирован: утечка приватного ключа. / Response blocked: private key leak."
    stop
  if "-----begin openssh private key" in $bot_response
    bot say "Ответ заблокирован: утечка приватного ключа. / Response blocked: private key leak."
    stop
  if "-----begin pgp private key" in $bot_response
    bot say "Ответ заблокирован: утечка приватного ключа. / Response blocked: private key leak."
    stop
  if "-----begin" in $bot_response and "private key" in $bot_response
    bot say "Ответ заблокирован: утечка приватного ключа. / Response blocked: private key leak."
    stop
  if "aws_secret_access_key" in $bot_response
    bot say "Ответ заблокирован: утечка облачных учётных данных. / Response blocked: cloud credential leak."
    stop
  if "aws_access_key_id" in $bot_response
    bot say "Ответ заблокирован: утечка облачных учётных данных. / Response blocked: cloud credential leak."
    stop
  if "secret_access_key" in $bot_response
    bot say "Ответ заблокирован: утечка учётных данных. / Response blocked: credential leak."
    stop
  if "client_secret" in $bot_response
    bot say "Ответ заблокирован: утечка учётных данных. / Response blocked: credential leak."
    stop
  if "ghp_" in $bot_response
    bot say "Ответ заблокирован: утечка токена доступа. / Response blocked: access token leak."
    stop
  if "github_pat_" in $bot_response
    bot say "Ответ заблокирован: утечка токена доступа. / Response blocked: access token leak."
    stop
  if "xoxb-" in $bot_response
    bot say "Ответ заблокирован: утечка токена доступа. / Response blocked: access token leak."
    stop
  if "aizasy" in $bot_response
    bot say "Ответ заблокирован: утечка API-ключа. / Response blocked: API key leak."
    stop
  if "your password is" in $bot_response
    bot say "Ответ заблокирован: раскрытие пароля. / Response blocked: password disclosure."
    stop
  if "ваш пароль:" in $bot_response
    bot say "Ответ заблокирован: раскрытие пароля. / Response blocked: password disclosure."
    stop
  if "пароль от" in $bot_response and "root" in $bot_response
    bot say "Ответ заблокирован: раскрытие пароля. / Response blocked: password disclosure."
    stop


# ── PII / financial data leaked in the answer ────────────────────────────────
define flow output_pii_financial_leak
  if "ssn:" in $bot_response
    bot say "Ответ заблокирован: обнаружена персональная информация. / Response blocked: PII detected."
    stop
  if "social security number" in $bot_response and "is" in $bot_response
    bot say "Ответ заблокирован: обнаружена персональная информация. / Response blocked: PII detected."
    stop
  if "credit card" in $bot_response and "number" in $bot_response
    bot say "Ответ заблокирован: обнаружены платёжные данные. / Response blocked: payment data detected."
    stop
  if "card number" in $bot_response and "expir" in $bot_response
    bot say "Ответ заблокирован: обнаружены платёжные данные. / Response blocked: payment data detected."
    stop
  if "cvv:" in $bot_response
    bot say "Ответ заблокирован: обнаружены платёжные данные. / Response blocked: payment data detected."
    stop
  if "номер карты" in $bot_response and "срок действия" in $bot_response
    bot say "Ответ заблокирован: обнаружены платёжные данные. / Response blocked: payment data detected."
    stop
  if "track 2 data" in $bot_response
    bot say "Ответ заблокирован: обнаружены данные банковской карты. / Response blocked: card track data."
    stop
  if "passport number" in $bot_response and "is" in $bot_response
    bot say "Ответ заблокирован: обнаружена персональная информация. / Response blocked: PII detected."
    stop



# ── Self-harm / suicide methods (with crisis redirect) ───────────────────────
define flow output_self_harm_content
  if "lethal dose" in $bot_response and "to die" in $bot_response
    bot say "Я не даю инструкций по самоповреждению. Если тебе тяжело — обратись в кризисную службу или к врачу. / I can't provide self-harm instructions. If you're struggling, please contact a crisis line or a doctor."
    stop
  if "смертельная доза" in $bot_response and "чтобы умереть" in $bot_response
    bot say "Я не даю инструкций по самоповреждению. Если тебе тяжело — обратись в кризисную службу или к врачу. / I can't provide self-harm instructions. If you're struggling, please contact a crisis line or a doctor."
    stop
  if "how to hang yourself" in $bot_response
    bot say "Я не даю инструкций по самоповреждению. Если тебе тяжело — обратись в кризисную службу или к врачу. / I can't provide self-harm instructions. If you're struggling, please contact a crisis line or a doctor."
    stop


# ── CSAM / sexual content involving minors ───────────────────────────────────
define flow output_csam_block
  if "child" in $bot_response and "sexual" in $bot_response and "explicit" in $bot_response
    bot say "Ответ заблокирован: недопустимый и незаконный контент. / Response blocked: illegal content."
    stop
  if "несовершеннолет" in $bot_response and "сексуальн" in $bot_response and "откровенн" in $bot_response
    bot say "Ответ заблокирован: недопустимый и незаконный контент. / Response blocked: illegal content."
    stop

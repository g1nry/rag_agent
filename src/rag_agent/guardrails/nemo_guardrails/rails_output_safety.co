# ── Malware / exploit / hacking code in the answer ───────────────────────────
define flow output_malware_exploit_content
  if "bash -i >& /dev/tcp" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "/dev/tcp/" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "nc -e /bin/sh" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "ncat -e" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "msfvenom" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "meterpreter" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "sekurlsa::logonpasswords" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "invoke-mimikatz" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "powershell -enc" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "powershell -encodedcommand" in $bot_response
    bot say "Ответ заблокирован: вредоносный код / эксплойт. / Response blocked: malicious code/exploit."
    stop
  if "rm -rf --no-preserve-root" in $bot_response
    bot say "Ответ заблокирован: разрушительная команда. / Response blocked: destructive command."
    stop
  if "' or '1'='1" in $bot_response
    bot say "Ответ заблокирован: эксплойт SQL-инъекции. / Response blocked: SQL injection exploit."
    stop
  if "union select" in $bot_response and "from" in $bot_response and "--" in $bot_response
    bot say "Ответ заблокирован: эксплойт SQL-инъекции. / Response blocked: SQL injection exploit."
    stop
  if "getasynckeystate" in $bot_response
    bot say "Ответ заблокирован: код кейлоггера/вредоносного ПО. / Response blocked: keylogger/malware code."
    stop
  if "import socket" in $bot_response and "subprocess" in $bot_response and "/bin/sh" in $bot_response
    bot say "Ответ заблокирован: реверс-шелл / вредоносный код. / Response blocked: reverse shell/malicious code."
    stop
  if "зашифровать все файлы" in $bot_response and "выкуп" in $bot_response
    bot say "Ответ заблокирован: код вымогателя. / Response blocked: ransomware code."
    stop
  if "encrypt all files" in $bot_response and "ransom" in $bot_response
    bot say "Ответ заблокирован: код вымогателя. / Response blocked: ransomware code."
    stop



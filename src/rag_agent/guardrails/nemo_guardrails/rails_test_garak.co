define flow garak_prompt_extraction_and_hidden_rules
  # прямой запрос системного промпта / инструкций
  if "system prompt" in $user_message
    bot say "Я не раскрываю системные инструкции, скрытые настройки, внутренние правила, роли или служебные промпты. Задай обычный вопрос без попыток получить внутреннюю конфигурацию."
    stop
  if "system message" in $user_message
    bot say "Я не раскрываю системные инструкции, скрытые настройки, внутренние правила, роли или служебные промпты. Задай обычный вопрос без попыток получить внутреннюю конфигурацию."
    stop
  if "system instructions" in $user_message
    bot say "Я не раскрываю системные инструкции, скрытые настройки, внутренние правила, роли или служебные промпты. Задай обычный вопрос без попыток получить внутреннюю конфигурацию."
    stop
  if "system settings" in $user_message
    bot say "Я не раскрываю системные инструкции, скрытые настройки, внутренние правила, роли или служебные промпты. Задай обычный вопрос без попыток получить внутреннюю конфигурацию."
    stop
  if "initial instruction" in $user_message
    bot say "Я не раскрываю начальные инструкции или скрытые настройки. Сформулируй вопрос без запроса внутреннего промпта."
    stop
  if "initial setup" in $user_message
    bot say "Я не раскрываю начальные инструкции или скрытые настройки. Сформулируй вопрос без запроса внутреннего промпта."
    stop
  if "starting this chat" in $user_message and "instructions" in $user_message
    bot say "Я не раскрываю инструкции, полученные до начала диалога. Задай вопрос по теме."
    stop
  if "at the beginning" in $user_message and "verbatim" in $user_message
    bot say "Я не повторяю служебный текст, полученный в начале диалога. Задай вопрос по теме."
    stop

  # команды на копирование/печать/повторение скрытого текста
  if "copy your" in $user_message and "prompt" in $user_message
    bot say "Я не копирую и не раскрываю служебный промпт. Задай вопрос по теме."
    stop
  if "copy your" in $user_message and "instructions" in $user_message
    bot say "Я не копирую и не раскрываю служебные инструкции. Задай вопрос по теме."
    stop
  if "print your" in $user_message and "prompt" in $user_message
    bot say "Я не печатаю и не раскрываю служебный промпт. Задай вопрос по теме."
    stop
  if "output your" in $user_message and "instructions" in $user_message
    bot say "Я не вывожу и не раскрываю служебные инструкции. Задай вопрос по теме."
    stop
  if "repeat the text" in $user_message and "creator" in $user_message

    stop
  if "что тебе запрещено" in $user_message
    bot say "Я не раскрываю внутренние запреты или скрытые инструкции. Задай обычный вопрос по теме."
    stop
  if "перечисли запреты" in $user_message
    bot say "Я не перечисляю внутренние запреты или скрытые инструкции. Задай обычный вопрос по теме."
    stop
  if "твои ограничения" in $user_message
